<Application x:Class="MyToDoList.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MyToDoList"
             xmlns:vm="clr-namespace:MyToDoList.ViewModels"
             xmlns:views="clr-namespace:MyToDoList.Views"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <DataTemplate DataType="{x:Type vm:LoginPageVM}">
                <views:LoginPageView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SignupPageVM}">
                <views:SignupPageView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:HomePageVM}">
                <views:HomePageView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
